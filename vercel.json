{
  "buildCommand": "cd client && npm install && npm run build && cp dist/index.html dist/404.html",
  "outputDirectory": "client/dist",
  "rewrites": [
    { "source": "/api/(.*)", "destination": "/api" }
  ],
  "functions": {
    "api/index.js": {
      "memory": 256,
      "maxDuration": 30
    }
  }
}
